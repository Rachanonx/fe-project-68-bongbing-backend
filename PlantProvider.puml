@startuml Rental Car Booking Sequence Diagram

header BingBong's Sequence Diagram
footer Page %page% of %lastpage%
title "Rental Car Provider Sequence Diagram"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:providers" as routerProviders
participant "<<controllers>>\n:providers" as controllersProviders
participant "<<model>>\n:Provider" as modelProvider
database "<<MongoDB>>\n:providers" as ProvidersDatabase

client -> server ++: req.get('/api/v1/providers')
server -> routerProviders ++: app.use('/api/v1/providers', providers)
routerProviders -> controllersProviders ++: getProviders()
controllersProviders -> modelProvider ++: find()
modelProvider -> ProvidersDatabase ++: ProviderSchema
ProvidersDatabase --> modelProvider --: providers[]
controllersProviders <-- modelProvider --: providers[]
controllersProviders -> client --: response

client -> server ++: req.get('/api/v1/providers/:id')
server -> routerProviders ++: app.use('/api/v1/providers', providers)
routerProviders -> controllersProviders ++: getProvider()
controllersProviders -> modelProvider ++: findById(req.params.id)
modelProvider -> ProvidersDatabase ++: ProviderSchema
ProvidersDatabase --> modelProvider --: provider
controllersProviders <-- modelProvider --: provider
controllersProviders -> client --: response

client -> server ++: req.post('/api/v1/providers')
server -> routerProviders ++: app.use('/api/v1/providers', providers)
routerProviders -> controllersProviders ++: createProvider()
controllersProviders -> modelProvider ++: create(req.body)
modelProvider -> ProvidersDatabase ++: ProviderSchema
ProvidersDatabase --> modelProvider --: provider
controllersProviders <-- modelProvider --: provider
controllersProviders -> client --: response

client -> server ++: req.put('/api/v1/providers/:id')
server -> routerProviders ++: app.use('/api/v1/providers', providers)
routerProviders -> controllersProviders ++: updateProvider()
controllersProviders -> modelProvider ++: findByIdAndUpdate(req.params.id, req.body)
modelProvider -> ProvidersDatabase ++: ProviderSchema
ProvidersDatabase --> modelProvider --: updatedProvider
controllersProviders <-- modelProvider --: updatedProvider
controllersProviders -> client --: response

client -> server ++: req.delete('/api/v1/providers/:id')
server -> routerProviders ++: app.use('/api/v1/providers', providers)
routerProviders -> controllersProviders ++: deleteProvider()
controllersProviders -> modelProvider ++: findByIdAndDelete(req.params.id)
modelProvider -> ProvidersDatabase ++: ProviderSchema
ProvidersDatabase --> modelProvider --: deletedProvider
controllersProviders <-- modelProvider --: deletedProvider
controllersProviders -> client --: response

@enduml