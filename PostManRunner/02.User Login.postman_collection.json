{
  "info": {
    "_postman_id": "1ea4801f-a20d-439f-9797-c28c5aad2fad",
    "name": "02.User Login",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "52473461",
    "_collection_link": "https://go.postman.co/collection/52473461-1ea4801f-a20d-439f-9797-c28c5aad2fad?source=collection_link"
  },
  "item": [
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "pm.test(\"Response has token\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"token\");\r",
              "});\r",
              "\r",
              "pm.collectionVariables.set(\"TOKEN\", pm.response.json().token);\r",
              "\r",
              "console.log(\"Token saved:\", jsonData.token);\r",
              "\r",
              "pm.execution.setNextRequest(\"getMe\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"email\": \"user@gmail.com\",\r\n    \"password\": \"12345678\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{url}}/api/v1/auth/login",
          "host": [
            "{{url}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "getMe",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"User role is user\", function () {\r",
              "    pm.expect(pm.response.json().data.role).to.eql(\"user\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{TOKEN}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{url}}/api/v1/auth/me",
          "host": [
            "{{url}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "me"
          ]
        }
      },
      "response": []
    }
  ],
