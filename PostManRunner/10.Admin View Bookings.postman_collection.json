  },
  "item": [
    {
      "name": "Login Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "pm.test(\"Response has token\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"token\");\r",
              "});\r",
              "\r",
              "pm.collectionVariables.set(\"TOKEN\", pm.response.json().token);\r",
              "\r",
              "console.log(\"Token saved:\", jsonData.token);\r",
              "\r",
              "pm.execution.setNextRequest(\"Show All Bookings\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"email\": \"admin@gmail.com\",\r\n    \"password\": \"12345678\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{url}}/api/v1/auth/login",
          "host": [
            "{{url}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Show All Bookings",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "const users = jsonData.data.map(item => item.user);\r",
              "const uniqueUsers = [...new Set(users)];\r",
              "\r",
              "pm.test(\"There is more than 1 unique user\", function () {\r",
              "    pm.expect(uniqueUsers.length).to.be.above(1);\r",
              "});\r",
              "\r",
              "pm.collectionVariables.set(\"bookingID\", jsonData.data[0]._id);\r",
              "pm.execution.setNextRequest(\"Show ONE Bookings\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{TOKEN}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{url}}/api/v1/bookings",
          "host": [
            "{{url}}"
          ],
          "path": [
            "api",
            "v1",
            "bookings"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Show ONE Bookings",
      "event": [
        {
