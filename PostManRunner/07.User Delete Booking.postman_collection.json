  "item": [
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "pm.test(\"Response has token\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"token\");\r",
              "});\r",
              "\r",
              "pm.collectionVariables.set(\"TOKEN\", pm.response.json().token);\r",
              "\r",
              "console.log(\"Token saved:\", jsonData.token);\r",
              "\r",
              "pm.execution.setNextRequest(\"Get booking\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"email\": \"user1@gmail.com\",\r\n    \"password\": \"12345678\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{url}}/api/v1/auth/login",
          "host": [
            "{{url}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"There are some booking\", function() {\r",
              "    pm.expect(pm.response.json().count).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.collectionVariables.set(\"bookingID\", pm.response.json().data[0]._id);\r",
              "pm.collectionVariables.set(\"bookingCount\", pm.response.json().count);\r",
              "\r",
              "pm.execution.setNextRequest(\"Delete Booking\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{TOKEN}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{url}}/api/v1/bookings",
          "host": [
            "{{url}}"
          ],
          "path": [
            "api",
            "v1",
            "bookings"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Delete Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "const oldCount = pm.collectionVariables.get(\"bookingCount\");\r",
              "\r",
              "pm.test(\"BookingCount has changed\", function () {\r",
              "    pm.expect(jsonData.count).to.not.equal(oldCount);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{TOKEN}}",
              "type": "string"
            }
          ]
        },
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{url}}/api/v1/bookings/{{bookingID}}",
          "host": [
            "{{url}}"
          ],
          "path": [
            "api",
            "v1",
            "bookings",
            "{{bookingID}}"
          ]
        }
      },
      "response": []
    }
  ],
